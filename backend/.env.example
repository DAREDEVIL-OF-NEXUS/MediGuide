# ==========================================
# MediGuide AI - Environment Variables
# ==========================================

# Core Settings
DATABASE_URL=postgresql+asyncpg://mediguide:mediguide@localhost:5432/mediguide
FALLBACK_SQLITE_URL=sqlite+aiosqlite:///./mediguide.db
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-secret-key-change-in-production

# API Keys
GEMINI_API_KEY=your-gemini-key
OPENFDA_API_KEY=your-openfda-key-optional

# Feature Flags
USE_GEMINI=true
USE_YOLO=false
USE_RULE_ENGINE=true
USE_LOCAL_ALARM=true
USE_EMAIL_REMINDERS=false
USE_SQLITE_FALLBACK=true
USE_AI_ASSISTANT=true
USE_MEDICINE_LIBRARY=true
USE_REAL_MEDICINE_DATABASE=true
USE_RAG=true
USE_OLLAMA=false

# RAG & Embeddings
VECTOR_DB_PATH=./chroma_db
